# Auto detect text files and perform LF normalization
* text=auto

# JavaScript/TypeScript files
*.js text=auto eol=lf
*.jsx text=auto eol=lf
*.ts text=auto eol=lf
*.tsx text=auto eol=lf

# Vue files
*.vue text=auto eol=lf

# Markdown files
*.md text=auto eol=lf

# CSS files
*.css text=auto eol=lf
*.scss text=auto eol=lf
*.sass text=auto eol=lf

# JSON files
*.json text=auto eol=lf

# Configuration files
*.yml text=auto eol=lf
*.yaml text=auto eol=lf
*.toml text=auto eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.svg text=auto eol=lf
*.ico binary
*.woff2 binary
*.woff binary
*.ttf binary